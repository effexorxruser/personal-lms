# Phase 1: секретов в этом файле нет. Реальные секреты хранить только в локальном .env и не коммитить.

# Название приложения, используется в FastAPI metadata и интерфейсе при необходимости.
# Секрет: нет. Обязательно менять: нет.
PERSONAL_LMS_APP_NAME=personal-lms

# Включает debug mode для локальной разработки.
# Секрет: нет. Обязательно менять: для production оставить false.
PERSONAL_LMS_DEBUG=false

# URL подключения к базе данных. По умолчанию используется локальный SQLite файл в instance/.
# Секрет: нет для SQLite. Обязательно менять: при переносе на другой путь или другой database backend.
PERSONAL_LMS_DATABASE_URL=sqlite:///./instance/personal_lms.db
