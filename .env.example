# Phase 2: секреты не хранятся в репозитории. Значения в этом файле примерные.

# Название приложения для FastAPI metadata и базового UI.
# Секрет: нет. Обязательно менять: нет.
PERSONAL_LMS_APP_NAME=personal-lms

# Включает debug mode в приложении.
# Секрет: нет. Обязательно менять: для production оставить false.
PERSONAL_LMS_DEBUG=false

# URL подключения к SQLite базе данных.
# Секрет: нет для локального SQLite. Обязательно менять: при смене пути к файлу базы.
PERSONAL_LMS_DATABASE_URL=sqlite:///./instance/personal_lms.db

# Ключ подписи cookie-сессии (SessionMiddleware).
# Секрет: да. Обязательно менять: да, перед любым shared/prod запуском.
PERSONAL_LMS_SESSION_SECRET_KEY=change-me-before-production

# Включает Lain AI Helper v1.0.
# Секрет: нет. Обязательно менять: нет.
PERSONAL_LMS_AI_HELPER_ENABLED=true

# API ключ OpenAI для online-режима helper.
# Секрет: да. Обязательно менять: да, если нужен online-режим.
PERSONAL_LMS_OPENAI_API_KEY=

# Модель для Lain helper.
# Секрет: нет. Обязательно менять: нет.
PERSONAL_LMS_AI_HELPER_MODEL=gpt-4o-mini

# Таймаут ответа helper в секундах.
# Секрет: нет. Обязательно менять: нет.
PERSONAL_LMS_AI_HELPER_TIMEOUT_SECONDS=12

